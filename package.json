{
  "name": "gestia-rest",
  "version": "1.0.0",
  "description": "Sistema POS para restaurantes — gestia.rest",
  "main": "index.html",
  "scripts": {
    "dev": "serve -s . --listen 3000",
    "start": "serve -s . --listen 3000",
    "lan": "serve -s . --listen tcp://0.0.0.0:8080",
    "css:build": "tailwindcss -i styles/input.css -o styles/main.css --minify",
    "css:watch": "tailwindcss -i styles/input.css -o styles/main.css --watch"
  },
  "keywords": [
    "pos",
    "restaurant",
    "gestia",
    "sales",
    "sistema-pos"
  ],
  "author": "Gestia",
  "license": "MIT",
  "devDependencies": {
    "firebase-admin": "^13.6.1",
    "serve": "^14.2.0",
    "tailwindcss": "^3.4.19"
  }
}
